## VRT Custom Dev Instance
## Ports décalés pour coexister avec l'instance VRT officielle

## VRT version tags (custom builds)
VRT_API_VERSION=custom-dev
VRT_UI_VERSION=custom-dev
VRT_MIGRATION_VERSION=custom-dev

## Frontend
REACT_APP_API_URL=http://localhost:9200
PORT=9080

## Backend
APP_FRONTEND_URL=http://localhost:9080
APP_PORT=9200

OLLAMA_BASE_URL=http://host.docker.internal:11434

JWT_SECRET='jwtDevPrivateKey'
JWT_LIFE_TIME=1d
BODY_PARSER_JSON_LIMIT="5mb"

## DB (nom différent pour isolation totale)
POSTGRES_PORT=9432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=vrt_db_dev
